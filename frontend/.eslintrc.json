{
    "env": {
        "browser": true,
        "es2021": true
    },
    "extends": "eslint:recommended",
    "parserOptions": {
        "ecmaVersion": "latest",
        "sourceType": "script"
    },
    "globals": {
        "marked": "readonly"
    },
    "rules": {
        "no-unused-vars": "warn",
        "no-console": "warn",
        "eqeqeq": "error"
    }
}
